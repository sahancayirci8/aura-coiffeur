/* RESET & CORE STYLES */
* {
    box-sizing: border-box;
    -webkit-tap-highlight-color: transparent;
}

body {
    margin: 0;
    font-family: 'Poppins', sans-serif;
    background-color: #070706;
    color: #f5f5f5;
    min-height: 100vh;
    overflow-x: hidden;
    position: relative;
}

/* HAFİF HAREKETLİ LUXURY ARKA PLAN */
.luxury-bg-glow {
    position: fixed;
    top: -20%;
    left: -10%;
    width: 70vw;
    height: 70vw;
    background: radial-gradient(circle, rgba(212, 175, 55, 0.04) 0%, transparent 70%);
    z-index: -1;
    animation: floatGlow 18s infinite alternate ease-in-out;
}
.luxury-bg-glow-2 {
    position: fixed;
    bottom: -10%;
    right: -10%;
    width: 60vw;
    height: 60vw;
    background: radial-gradient(circle, rgba(170, 124, 17, 0.03) 0%, transparent 70%);
    z-index: -1;
    animation: floatGlow 24s infinite alternate-reverse ease-in-out;
}
@keyframes floatGlow {
    0% { transform: translate(0, 0) scale(1); }
    100% { transform: translate(40px, 40px) scale(1.1); }
}

/* GRADIENT TEXTS */
.gold-text {
    color: #d4af37 !important;
    background: linear-gradient(to right, #f3e0aa, #d4af37, #aa7c11);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
}
.gold-text-static {
    color: #d4af37;
    font-size: 42px;
    margin: 10px 0;
    font-family: 'Cinzel', serif;
    font-weight: 700;
}

/* GİRİŞ EKRANI */
.login-container {
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100vh;
    width: 100%;
    padding: 20px;
}

.login-box {
    background: rgba(14, 13, 11, 0.9);
    backdrop-filter: blur(25px);
    border: 1px solid rgba(212, 175, 55, 0.2);
    padding: 40px 30px;
    border-radius: 20px;
    text-align: center;
    box-shadow: 0 25px 60px rgba(0, 0, 0, 0.8);
    max-width: 380px;
    width: 100%;
}

.logo-3d {
    font-family: 'Cinzel', serif;
    font-size: 48px;
    font-weight: 700;
    color: #d4af37;
    text-shadow: 0 2px 4px rgba(0,0,0,0.6);
    letter-spacing: 6px;
}

.sub-title-3d {
    font-family: 'Poppins', sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: #ffffff;
    letter-spacing: 4px;
    margin-top: -5px;
    margin-bottom: 5px;
}

.expert-tag {
    color: #c5a880; 
    letter-spacing: 2px; 
    font-size: 10px; 
    margin-bottom: 30px;
    text-transform: uppercase;
}

.input-group input {
    width: 100%;
    padding: 14px;
    margin-bottom: 20px;
    background: rgba(0, 0, 0, 0.7);
    border: 1px solid #25221a;
    border-radius: 8px;
    color: #fff;
    font-size: 14px;
    transition: all 0.3s;
}
.input-group input:focus {
    border-color: #d4af37;
    outline: none;
    box-shadow: 0 0 10px rgba(212, 175, 55, 0.2);
}

.gold-btn {
    background: linear-gradient(135deg, #f3e0aa 0%, #d4af37 50%, #aa7c11 100%);
    color: #000;
    border: none;
    padding: 14px 28px;
    font-weight: 600;
    letter-spacing: 1.5px;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.3s ease;
}
.gold-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(212, 175, 55, 0.35);
}

/* APP LAYOUT & SIDEBAR */
.app-container {
    display: flex;
    width: 100%;
    min-height: 100vh;
}

.sidebar {
    width: 280px;
    background: #090807;
    border-right: 1px solid #161411;
    padding: 30px 20px;
    display: flex;
    flex-direction: column;
    z-index: 999;
    transition: transform 0.3s ease;
}

.sidebar-brand h1 {
    font-family: 'Cinzel', serif;
    color: #d4af37;
    margin: 0;
    letter-spacing: 4px;
    font-size: 26px;
}
.sidebar-brand span {
    font-size: 10px;
    letter-spacing: 4px;
    color: #fff;
    display: block;
}

.welcome-box {
    background: rgba(212, 175, 55, 0.06);
    border: 1px solid rgba(212, 175, 55, 0.15);
    padding: 12px;
    border-radius: 6px;
    text-align: center;
    margin: 25px 0;
    font-size: 11px;
    letter-spacing: 2px;
    color: #d4af37;
    font-weight: 600;
}

.menu-btn {
    background: transparent;
    border: none;
    color: #999;
    padding: 14px 16px;
    text-align: left;
    font-size: 13.5px;
    cursor: pointer;
    border-radius: 8px;
    margin-bottom: 6px;
    transition: all 0.2s ease;
}
.menu-btn:hover, .menu-btn.active {
    background: linear-gradient(to right, rgba(212, 175, 55, 0.1), transparent);
    border-left: 3px solid #d4af37;
    color: #d4af37;
}
.logout-btn:hover {
    background: #c0392b !important;
    color: #fff !important;
    border: none;
}

/* MOBİL BUTONLAR */
.menu-toggle-btn {
    display: none;
    position: fixed;
    top: 15px;
    left: 15px;
    background: linear-gradient(135deg, #f3e0aa 0%, #d4af37 100%);
    color: #000;
    border: none;
    padding: 10px 16px;
    border-radius: 6px;
    font-size: 20px;
    cursor: pointer;
    z-index: 1000;
    box-shadow: 0 4px 15px rgba(0,0,0,0.4);
}
.menu-close-btn {
    display: none;
    background: #c0392b;
    color: white;
    border: none;
    padding: 12px;
    border-radius: 6px;
    margin-bottom: 25px;
    font-weight: 600;
    cursor: pointer;
    letter-spacing: 1px;
}

/* MAIN PANEL CONTENT */
.main-content {
    flex: 1;
    padding: 40px;
    max-width: 100%;
    box-sizing: border-box;
}

.page-title {
    font-family: 'Cinzel', serif;
    font-size: 24px;
    border-bottom: 1px solid #161411;
    padding-bottom: 15px;
    margin-bottom: 30px;
    letter-spacing: 1px;
}

.stats-container {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 20px;
    margin-bottom: 30px;
}

.stat-box {
    background: rgba(16, 15, 13, 0.5);
    border: 1px solid #1d1a15;
    padding: 20px;
    border-radius: 12px;
    backdrop-filter: blur(5px);
}
.stat-box span {
    font-size: 10px;
    color: #aa7c11;
    text-transform: uppercase;
    letter-spacing: 1px;
}
.stat-box h2 {
    margin: 6px 0 0 0;
    font-size: 24px;
}
.status-indicator {
    color: #2ecc71; 
    font-size: 13px; 
    font-weight: 600; 
    display: block; 
    margin-top: 8px;
}

.premium-card {
    background: rgba(12, 11, 10, 0.75);
    border: 1px solid #1d1a15;
    padding: 25px;
    border-radius: 16px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.4);
    margin-bottom: 20px;
}
.summary-cash-card {
    background: linear-gradient(135deg, #181612 0%, #080807 100%); 
    border: 1px solid #d4af37; 
    text-align: center; 
    padding: 40px 20px;
}
.cash-title-tag {
    letter-spacing: 2px; 
    color: #888; 
    font-size: 11px;
}

/* RESPONSIVE TABLES */
.table-responsive {
    width: 100%;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
}
.luxury-table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 5px;
    min-width: 650px;
}
.luxury-table th {
    background: #0b0a09;
    color: #d4af37;
    font-weight: 500;
    text-transform: uppercase;
    font-size: 11px;
    letter-spacing: 1px;
    padding: 14px;
    text-align: left;
    border-bottom: 2px solid #1d1a15;
}
.luxury-table td {
    padding: 14px;
    border-bottom: 1px solid #141311;
    font-size: 13.5px;
    color: #dbdbdb;
}
.empty-state-text {
    text-align: center;
    color: #555;
    font-style: italic;
    padding: 25px 0;
}

/* FORM ELEMENTS */
.form-group { margin-bottom: 18px; }
.form-group label { display: block; font-size: 11px; color: #888; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 6px; }
.form-group input, .form-group select { width: 100%; padding: 12px; background: #000; border: 1px solid #1d1a15; border-radius: 8px; color: #fff; font-size: 13.5px; }
.form-group input:focus, .form-group select:focus { border-color: #d4af37; outline: none; }

/* 💎 YENİ ULTRA LUXURY ADİSYON KARTI TASARIMI 💎 */
.appointment-wrapper {
    display: flex;
    flex-wrap: wrap;
    gap: 30px;
}

.receipt-wrapper-area {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
}

.premium-receipt-card {
    width: 340px;
    height: 480px;
    background: linear-gradient(135deg, #131210 0%, #090908 100%);
    color: #ffffff;
    padding: 18px;
    border-radius: 16px;
    box-shadow: 0 20px 45px rgba(0,0,0,0.7);
    border: 1px solid rgba(212, 175, 55, 0.35);
    box-sizing: border-box;
    position: relative;
}

.receipt-inner-border {
    border: 1px solid rgba(212, 175, 55, 0.15);
    height: 100%;
    width: 100%;
    border-radius: 10px;
    padding: 25px 20px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    box-sizing: border-box;
}

.receipt-card-header {
    text-align: center;
}
.receipt-card-header .brand-main {
    font-family: 'Cinzel', serif;
    font-size: 32px;
    font-weight: 700;
    letter-spacing: 6px;
    color: #d4af37;
    line-height: 1;
}
.receipt-card-header .brand-sub {
    font-family: 'Poppins', sans-serif;
    font-size: 12px;
    letter-spacing: 4px;
    color: #ffffff;
    margin-top: 4px;
    opacity: 0.8;
}
.premium-badge {
    display: inline-block;
    font-size: 9px;
    letter-spacing: 2px;
    color: #000000;
    background: linear-gradient(135deg, #f3e0aa 0%, #d4af37 100%);
    padding: 3px 10px;
    border-radius: 20px;
    margin-top: 12px;
    font-weight: 600;
}

.receipt-card-divider {
    border-top: 1px dashed rgba(212, 175, 55, 0.25);
    margin: 15px 0;
    width: 100%;
}

.receipt-info-row {
    display: flex;
    justify-content: space-between;
    margin-bottom: 12px;
    font-size: 11px;
}
.receipt-info-row .label {
    color: rgba(212, 175, 55, 0.7);
    letter-spacing: 1px;
    font-weight: 500;
}
.receipt-info-row .value {
    color: #ffffff;
    font-weight: 400;
    text-align: right;
}

.service-display-box {
    background: rgba(212, 175, 55, 0.04);
    border: 1px dashed rgba(212, 175, 55, 0.2);
    border-radius: 8px;
    padding: 15px;
    text-align: center;
    margin-top: 15px;
}
.service-display-box .service-title {
    font-family: 'Cinzel', serif;
    color: #d4af37;
    font-size: 18px;
    font-weight: 600;
    letter-spacing: 1px;
}
.service-display-box .service-tag {
    font-size: 10px;
    color: #888;
    margin-top: 4px;
}

.receipt-card-footer {
    text-align: center;
}
.total-price-label {
    font-size: 10px;
    color: rgba(212, 175, 55, 0.7);
    letter-spacing: 2px;
}
.total-price-value {
    font-family: 'Cinzel', serif;
    font-size: 34px;
    font-weight: 700;
    color: #d4af37;
    margin: 2px 0 6px 0;
}
.luxury-footer-note {
    font-size: 9px;
    color: #555;
    font-style: italic;
    letter-spacing: 0.5px;
}

.download-receipt-btn {
    width: 100%;
    background: #141311;
    color: #d4af37;
    border: 1px solid rgba(212, 175, 55, 0.5);
    padding: 13px;
    border-radius: 8px;
    font-weight: 600;
    cursor: pointer;
    letter-spacing: 1px;
    transition: all 0.2s ease;
}
.download-receipt-btn:hover {
    background: #d4af37;
    color: #000;
}

/* RESPONSIVE DESIGN */
@media (max-width: 768px) {
    .menu-toggle-btn { display: block; }
    .menu-close-btn { display: block; }
    
    .sidebar {
        position: fixed;
        transform: translateX(-300px);
        top: 0;
        bottom: 0;
        left: 0;
        box-shadow: 15px 0 40px rgba(0,0,0,0.8);
    }
    .sidebar.mobile-open {
        transform: translateX(0);
    }
    
    .main-content {
        padding: 80px 15px 20px 15px;
    }
    
    .appointment-wrapper {
        flex-direction: column;
    }
    .receipt-wrapper-area {
        width: 100%;
    }
    .premium-receipt-card {
        width: 100%;
        max-width: 340px;
    }
}
